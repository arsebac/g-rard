generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  avatarUrl    String?  @map("avatar_url") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")

  createdProjects Project[]       @relation("ProjectCreator")
  projects        ProjectMember[]
  assignedTasks   Task[]          @relation("TaskAssignee")
  createdTasks    Task[]          @relation("TaskCreator")
  comments        Comment[]
  activityLogs    ActivityLog[]
  attachments     Attachment[]
  wikiPages       WikiPage[]
  taskLinks       TaskLink[]

  @@map("users")
}

model Project {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(255)
  key         String?       @unique @db.VarChar(5)
  description String?       @db.Text
  color       String        @default("#6366f1") @db.VarChar(7)
  status      ProjectStatus @default(actif)
  isPublic    Boolean       @default(true) @map("is_public")
  createdBy   Int           @map("created_by")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  creator             User                 @relation("ProjectCreator", fields: [createdBy], references: [id])
  members             ProjectMember[]
  tasks               Task[]
  labels              Label[]
  wikiPages           WikiPage[]
  ticketTypes         TicketType[]
  columns             ProjectColumn[]
  workflowTransitions WorkflowTransition[]
  sprints             Sprint[]

  @@map("projects")
}

model ProjectMember {
  projectId Int                @map("project_id")
  userId    Int                @map("user_id")
  role      ProjectMemberRole  @default(member)
  createdAt DateTime           @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_members")
}

enum ProjectMemberRole {
  admin
  member
}

enum ProjectStatus {
  actif
  archive
}

model Label {
  id        Int    @id @default(autoincrement())
  projectId Int    @map("project_id")
  name      String @db.VarChar(100)
  color     String @default("#94a3b8") @db.VarChar(7)

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   TaskLabel[]

  @@map("labels")
}

model Task {
  id          Int          @id @default(autoincrement())
  projectId   Int          @map("project_id")
  number      Int          @default(0)
  title       String       @db.VarChar(500)
  description String?      @db.Text
  status      TaskStatus   @default(a_faire)
  priority    TaskPriority @default(normale)
  assigneeId  Int?         @map("assignee_id")
  createdBy   Int          @map("created_by")
  startDate   DateTime?    @map("start_date") @db.Date
  endDate     DateTime?    @map("end_date") @db.Date
  dueDate     DateTime?    @map("due_date") @db.Date
  position    Int          @default(0)
  typeId      Int?         @map("type_id")
  parentId    Int?         @map("parent_id")
  sprintId    Int?         @map("sprint_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator    User         @relation("TaskCreator", fields: [createdBy], references: [id])
  type       TicketType?  @relation(fields: [typeId], references: [id], onDelete: SetNull)
  parent     Task?        @relation("TaskChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children   Task[]       @relation("TaskChildren")
  sprint     Sprint?      @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  labels     TaskLabel[]
  comments   Comment[]
  linksFrom  TaskLink[]   @relation("LinkSource")
  linksTo    TaskLink[]   @relation("LinkTarget")

  @@map("tasks")
}

enum TaskStatus {
  a_faire   @map("à_faire")
  en_cours
  termine   @map("terminé")
  bloque    @map("bloqué")
}

enum TaskPriority {
  basse
  normale
  haute
  urgente
}

model TaskLabel {
  taskId  Int @map("task_id")
  labelId Int @map("label_id")

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@map("task_labels")
}

model Comment {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  authorId  Int      @map("author_id")
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@map("comments")
}

model Attachment {
  id          Int            @id @default(autoincrement())
  entityType  AttachmentType @map("entity_type")
  entityId    Int            @map("entity_id")
  uploadedBy  Int            @map("uploaded_by")
  filename    String         @db.VarChar(255)
  storedPath  String         @map("stored_path") @db.VarChar(500)
  mimeType    String         @map("mime_type") @db.VarChar(100)
  sizeBytes   Int            @map("size_bytes")
  createdAt   DateTime       @default(now()) @map("created_at")

  uploader User @relation(fields: [uploadedBy], references: [id])

  @@map("attachments")
}

enum AttachmentType {
  task
  project
  wiki_page
}

model ActivityLog {
  id         Int          @id @default(autoincrement())
  entityType ActivityType @map("entity_type")
  entityId   Int          @map("entity_id")
  actorId    Int          @map("actor_id")
  action     String       @db.VarChar(100)
  oldValue   String?      @map("old_value") @db.Text
  newValue   String?      @map("new_value") @db.Text
  createdAt  DateTime     @default(now()) @map("created_at")

  actor User @relation(fields: [actorId], references: [id])

  @@map("activity_log")
}

enum ActivityType {
  task
  project
  wiki_page
}

model WikiPage {
  id          Int             @id @default(autoincrement())
  projectId   Int?            @map("project_id")
  parentId    Int?            @map("parent_id")
  title       String          @db.VarChar(500)
  slug        String          @db.VarChar(500)
  contentType WikiContentType @default(tiptap) @map("content_type")
  body        String          @db.LongText
  sourceFile  String?         @map("source_file") @db.VarChar(500)
  createdBy   Int             @map("created_by")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  project  Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   WikiPage?  @relation("WikiPageChildren", fields: [parentId], references: [id])
  children WikiPage[] @relation("WikiPageChildren")
  creator  User       @relation(fields: [createdBy], references: [id])

  @@unique([projectId, slug])
  @@map("wiki_pages")
}

enum WikiContentType {
  tiptap
  markdown
}

model TicketType {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  name      String   @db.VarChar(100)
  icon      String   @default("square") @db.VarChar(50)
  color     String   @default("#6366f1") @db.VarChar(7)
  isEpic    Boolean  @default(false) @map("is_epic")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("ticket_types")
}

model TaskLink {
  id        Int          @id @default(autoincrement())
  sourceId  Int          @map("source_id")
  targetId  Int          @map("target_id")
  linkType  TaskLinkType @map("link_type")
  createdBy Int          @map("created_by")
  createdAt DateTime     @default(now()) @map("created_at")

  source  Task @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target  Task @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)
  creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, linkType])
  @@map("task_links")
}

model Sprint {
  id        Int          @id @default(autoincrement())
  projectId Int          @map("project_id")
  name      String       @db.VarChar(255)
  goal      String?      @db.Text
  startDate DateTime?    @map("start_date")
  endDate   DateTime?    @map("end_date")
  status    SprintStatus @default(futur)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("sprints")
}

enum SprintStatus {
  futur
  actif
  termine   @map("terminé")
}


model ProjectColumn {
  id        Int     @id @default(autoincrement())
  projectId Int     @map("project_id")
  statusKey String  @map("status_key") @db.VarChar(50)
  label     String  @db.VarChar(100)
  color     String  @default("#94a3b8") @db.VarChar(7)
  position  Int     @default(0)
  visible   Boolean @default(true)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, statusKey])
  @@map("project_columns")
}

model WorkflowTransition {
  id         Int    @id @default(autoincrement())
  projectId  Int    @map("project_id")
  fromStatus String @map("from_status") @db.VarChar(50)
  toStatus   String @map("to_status") @db.VarChar(50)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, fromStatus, toStatus])
  @@map("workflow_transitions")
}

enum TaskLinkType {
  blocks
  is_blocked_by
  relates_to
  duplicates
  is_duplicated_by
  causes
  is_caused_by
}
