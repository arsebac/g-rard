generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  avatarUrl    String?  @map("avatar_url") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")

  createdProjects Project[]    @relation("ProjectCreator")
  assignedTasks   Task[]       @relation("TaskAssignee")
  createdTasks    Task[]       @relation("TaskCreator")
  comments        Comment[]
  activityLogs    ActivityLog[]
  attachments     Attachment[]
  wikiPages       WikiPage[]

  @@map("users")
}

model Project {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(255)
  description String?       @db.Text
  color       String        @default("#6366f1") @db.VarChar(7)
  status      ProjectStatus @default(actif)
  createdBy   Int           @map("created_by")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  creator  User      @relation("ProjectCreator", fields: [createdBy], references: [id])
  tasks    Task[]
  labels   Label[]
  wikiPages WikiPage[]

  @@map("projects")
}

enum ProjectStatus {
  actif
  archivé @map("archive")
}

model Label {
  id        Int    @id @default(autoincrement())
  projectId Int    @map("project_id")
  name      String @db.VarChar(100)
  color     String @default("#94a3b8") @db.VarChar(7)

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   TaskLabel[]

  @@map("labels")
}

model Task {
  id          Int          @id @default(autoincrement())
  projectId   Int          @map("project_id")
  title       String       @db.VarChar(500)
  description String?      @db.Text
  status      TaskStatus   @default(a_faire)
  priority    TaskPriority @default(normale)
  assigneeId  Int?         @map("assignee_id")
  createdBy   Int          @map("created_by")
  dueDate     DateTime?    @map("due_date") @db.Date
  position    Int          @default(0)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator  User        @relation("TaskCreator", fields: [createdBy], references: [id])
  labels   TaskLabel[]
  comments Comment[]

  @@map("tasks")
}

enum TaskStatus {
  a_faire   @map("à_faire")
  en_cours
  termine   @map("terminé")
  bloque    @map("bloqué")
}

enum TaskPriority {
  basse
  normale
  haute
  urgente
}

model TaskLabel {
  taskId  Int @map("task_id")
  labelId Int @map("label_id")

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@map("task_labels")
}

model Comment {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  authorId  Int      @map("author_id")
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@map("comments")
}

model Attachment {
  id          Int            @id @default(autoincrement())
  entityType  AttachmentType @map("entity_type")
  entityId    Int            @map("entity_id")
  uploadedBy  Int            @map("uploaded_by")
  filename    String         @db.VarChar(255)
  storedPath  String         @map("stored_path") @db.VarChar(500)
  mimeType    String         @map("mime_type") @db.VarChar(100)
  sizeBytes   Int            @map("size_bytes")
  createdAt   DateTime       @default(now()) @map("created_at")

  uploader User @relation(fields: [uploadedBy], references: [id])

  @@map("attachments")
}

enum AttachmentType {
  task
  project
  wiki_page
}

model ActivityLog {
  id         Int          @id @default(autoincrement())
  entityType ActivityType @map("entity_type")
  entityId   Int          @map("entity_id")
  actorId    Int          @map("actor_id")
  action     String       @db.VarChar(100)
  oldValue   String?      @map("old_value") @db.Text
  newValue   String?      @map("new_value") @db.Text
  createdAt  DateTime     @default(now()) @map("created_at")

  actor User @relation(fields: [actorId], references: [id])

  @@map("activity_log")
}

enum ActivityType {
  task
  project
  wiki_page
}

model WikiPage {
  id          Int             @id @default(autoincrement())
  projectId   Int?            @map("project_id")
  parentId    Int?            @map("parent_id")
  title       String          @db.VarChar(500)
  slug        String          @db.VarChar(500)
  contentType WikiContentType @default(tiptap) @map("content_type")
  body        String          @db.LongText
  sourceFile  String?         @map("source_file") @db.VarChar(500)
  createdBy   Int             @map("created_by")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  project  Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   WikiPage?  @relation("WikiPageChildren", fields: [parentId], references: [id])
  children WikiPage[] @relation("WikiPageChildren")
  creator  User       @relation(fields: [createdBy], references: [id])

  @@unique([projectId, slug])
  @@map("wiki_pages")
}

enum WikiContentType {
  tiptap
  markdown
}
